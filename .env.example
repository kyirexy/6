# VideoCapsule 环境变量配置
# 复制此文件为 .env 并填入实际值

# === API Keys ===
# 硅基流动 API Key (用于 ASR 语音识别)
# 获取地址: https://cloud.siliconflow.cn/i/TxUlXG3u
API_KEY=sk-xxxxxxxxxxxxxxxx

# DeepSeek API Key (用于 AI 榨汁，通过 LiteLLM 调用)
# 获取地址: https://platform.deepseek.com/
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxx

# === LLM 配置 ===
# LiteLLM 模型标识 (默认 DeepSeek-V3)
LLM_MODEL=deepseek/deepseek-chat

# === 服务配置 ===
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_PORT=3000

# === 数据库 ===
DATABASE_URL=sqlite:///./videocapsule.db
